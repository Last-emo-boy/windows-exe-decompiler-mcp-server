# =============================================================================
# .dockerignore - Windows EXE Decompiler MCP Server
# =============================================================================
# Exclude files and directories from Docker build context
# This reduces build time and final image size
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
.npmrc

# -----------------------------------------------------------------------------
# TypeScript Build Output (will be rebuilt in container)
# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test-data-*/
tmp-*/
*.test.ts
*.test.js
coverage/
.nyc_output/
jest.config.js

# -----------------------------------------------------------------------------
# IDE and Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Documentation (not needed in runtime image)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md  # Keep README for metadata

# -----------------------------------------------------------------------------
# OpenSpec (development artifacts, not needed in runtime)
# -----------------------------------------------------------------------------
openspec/
.kiro/

# -----------------------------------------------------------------------------
# Scripts and Helpers (not needed in runtime)
# -----------------------------------------------------------------------------
scripts/*
!scripts/validate-docker-full-stack.sh
run-tests.*
test-*.js
test-*.bat
test-*.ps1

# -----------------------------------------------------------------------------
# Docker (don't include Docker files in build context)
# -----------------------------------------------------------------------------
Dockerfile
.dockerignore
docker-compose*.yml
# NOTE: docker-entrypoint.sh is needed in the image, don't exclude it
# docker-entrypoint.sh

# -----------------------------------------------------------------------------
# Installation Scripts (not needed in runtime)
# -----------------------------------------------------------------------------
install-to-*.ps1
*_INSTALLATION.md

# -----------------------------------------------------------------------------
# Logs and Cache (should not be in build context)
# -----------------------------------------------------------------------------
*.log
logs/
cache/
data/
workspaces/
ghidra-projects/
ghidra-logs/

# -----------------------------------------------------------------------------
# Environment and Config (mount at runtime, don't build in)
# -----------------------------------------------------------------------------
.env
.env.*
*.env
config.json
*.local.json

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
LICENSE
.eslintignore
.eslintrc.json
.prettierignore
.prettierrc.json

# -----------------------------------------------------------------------------
# Examples (not needed in runtime)
# -----------------------------------------------------------------------------
examples/

# -----------------------------------------------------------------------------
# Frida Scripts (include in runtime, but exclude test files)
# -----------------------------------------------------------------------------
frida_scripts/*test*

# -----------------------------------------------------------------------------
# Workers (exclude test files, keep main workers)
# -----------------------------------------------------------------------------
workers/test_*.py
